{
  "manifest_version": "0.1.0",
  "program": {
    "image": "rimodock/purple-terminal-agent:latest",
    "entrypoint": "uv run --no-sync src/server.py --host 0.0.0.0 --port 9009",
    "network": {
      "endpoints": [
        {
          "name": "a2a",
          "port": 9009
        }
      ]
    },
    "env": {
      "PYTHONUNBUFFERED": "1",
      "PORT": "9009",
      "MAX_TURNS": "30",
      "MODEL": "deepseek/deepseek-v4-flash",
      "TASK_INDEX_PATH": "/app/data/task_index.json",
      "OPENROUTER_API_KEY": "${config.openrouter_api_key}"
    }
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "openrouter_api_key": {
        "type": "string",
        "title": "OpenRouter API Key",
        "secret": true
      }
    },
    "required": ["openrouter_api_key"]
  },
  "provides": {
    "a2a": {
      "kind": "a2a",
      "endpoint": "a2a"
    }
  },
  "exports": {
    "a2a": "a2a"
  }
}
